/* ===== ADMIN CMS PAGE ===== */
.admin-cms-container {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.admin-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.search-box {
  flex: 1;
  min-width: 200px;
  max-width: 400px;
}

.search-box input {
  width: 100%;
  padding: 10px 18px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-main);
  outline: none;
  font-size: 0.9375rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.search-box input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px var(--primary-light);
}

/* Top Performers */
.top-performers-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.performer-card {
  display: flex;
  align-items: center;
  gap: 16px;
  position: relative;
  overflow: hidden;
}

.performer-card .rank {
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--primary-light);
  line-height: 1;
  flex-shrink: 0;
  opacity: 0.6;
}

.performer-info { min-width: 0; }

.performer-info h3 {
  font-size: 1rem;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.performer-info p {
  font-size: 0.8125rem;
  color: var(--text-muted);
  margin-bottom: 6px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.performer-points { font-weight: 700; color: var(--primary); font-size: 0.9rem; }

/* CM Management Grid */
.cm-management-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 24px;
  align-items: start;
}

/* Table */
.cm-table-wrapper {
  margin-top: 16px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  border-radius: 10px;
  border: 1px solid var(--border);
}

.cm-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 500px;
}

.cm-table th {
  text-align: left;
  padding: 12px 16px;
  border-bottom: 2px solid var(--border);
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  white-space: nowrap;
  background: var(--background);
}

.cm-table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  font-size: 0.9rem;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cm-table tr:last-child td { border-bottom: none; }

.points-pill {
  background: var(--primary-light);
  color: var(--primary);
  padding: 4px 12px;
  border-radius: 999px;
  font-weight: 600;
  font-size: 0.8125rem;
  white-space: nowrap;
}

.text-btn {
  background: none;
  color: var(--primary);
  font-weight: 600;
  font-size: 0.875rem;
  padding: 4px 8px;
  border-radius: 6px;
  transition: background 0.2s;
}

.text-btn:hover { background: var(--primary-light); }

/* Add CM Form */
.admin-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 16px;
}

.admin-form .form-group {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.admin-form .form-group label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.admin-form input,
.admin-form select {
  width: 100%;
  padding: 11px 14px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--background);
  color: var(--text-main);
  font-family: var(--font-main);
  font-size: 0.9375rem;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.admin-form input:focus,
.admin-form select:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px var(--primary-light);
}

/* Bulk Import */
.bulk-import {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
  text-align: center;
}

.bulk-import p {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin-bottom: 12px;
}

/* Tablet */
@media (max-width: 1024px) {
  .cm-management-grid { grid-template-columns: 1fr; }
  .top-performers-row { grid-template-columns: 1fr; gap: 12px; }
}

/* Mobile */
@media (max-width: 640px) {
  .admin-header-row { flex-direction: column; align-items: stretch; }
  .search-box { max-width: 100%; }
  .bulk-import div { flex-direction: column; }
  .bulk-import .btn-primary,
  .bulk-import .btn-secondary { width: 100%; }
}
