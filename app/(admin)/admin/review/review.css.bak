/* ===== ADMIN REVIEW PAGE ===== */
.review-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Tab Switcher */
.tab-switcher {
  display: flex;
  gap: 8px;
  border-bottom: 2px solid var(--border);
  padding-bottom: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tab-switcher button {
  padding: 10px 20px;
  background: none;
  border-radius: 8px 8px 0 0;
  color: var(--text-muted);
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.2s;
  white-space: nowrap;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
}

.tab-switcher button:hover { color: var(--primary); }

.tab-switcher button.active {
  color: var(--primary);
  border-bottom-color: var(--primary);
  background: var(--primary-light);
}

/* Review Cards Grid */
.review-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: 20px;
}

.review-card {
  display: flex;
  flex-direction: column;
  gap: 18px;
  position: relative;
  overflow: hidden;
}

.review-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 600;
  flex-wrap: wrap;
  gap: 8px;
}

.task-type {
  color: var(--primary);
  background: var(--primary-light);
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.sub-date { color: var(--text-muted); font-size: 0.75rem; }

.review-content h3 {
  font-size: 1.125rem;
  margin-bottom: 14px;
  line-height: 1.3;
}

.summary-box, .proof-box { margin-bottom: 14px; }

.summary-box p:first-child,
.proof-box p:first-child {
  font-size: 0.8125rem;
  color: var(--text-muted);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

.work-summary {
  background: var(--background);
  padding: 14px;
  border-radius: 8px;
  font-size: 0.9rem;
  line-height: 1.6;
  border: 1px solid var(--border);
  word-break: break-word;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16px;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 12px;
}

.reward-info span {
  font-size: 0.8125rem;
  color: var(--text-muted);
  display: block;
}

.reward-info strong {
  font-size: 1.125rem;
  color: var(--primary);
}

.action-buttons {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn-reject {
  background: #fee2e2;
  color: #b91c1c;
  padding: 10px 18px;
  border-radius: var(--radius);
  font-weight: 600;
  font-size: 0.9rem;
  transition: background 0.2s;
}

.btn-reject:hover { background: #fecaca; }

/* Review Modal */
.review-modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: var(--radius);
  padding: 16px;
}

[data-theme='dark'] .review-modal-overlay {
  background: rgba(22, 27, 34, 0.96);
}

.review-modal {
  width: 100%;
  max-width: 380px;
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--primary);
}

.review-modal textarea {
  width: 100%;
  min-height: 100px;
  margin: 14px 0;
  padding: 12px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--background);
  color: var(--text-main);
  font-family: var(--font-main);
  font-size: 0.9rem;
  resize: vertical;
  outline: none;
}

.review-modal textarea:focus { border-color: var(--primary); }

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
}

.btn-text {
  background: none;
  color: var(--text-muted);
  font-weight: 600;
  padding: 8px 12px;
  border-radius: 8px;
  transition: background 0.2s;
}

.btn-text:hover { background: var(--background); }

.empty-state {
  text-align: center;
  padding: 48px 20px;
  color: var(--text-muted);
  grid-column: 1 / -1;
}

.empty-state p { font-size: 1rem; }

/* Tablet / Mobile */
@media (max-width: 768px) {
  .review-grid { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .review-footer { flex-direction: column; align-items: flex-start; }
  .action-buttons { width: 100%; }
  .action-buttons .btn-reject,
  .action-buttons .btn-primary { flex: 1; justify-content: center; }
  .modal-actions { justify-content: stretch; }
  .modal-actions .btn-text,
  .modal-actions .btn-primary { flex: 1; justify-content: center; }
}
